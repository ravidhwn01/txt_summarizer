#  add files to ignore
# .gitignore    
# Ignore Python bytecode files
__pycache__/
*.pyc
# Ignore virtual environment directories
venv/
env/
# Ignore Streamlit configuration files
.streamlit/config.toml
.streamlit/secrets.toml
# Ignore log files
*.log
# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/
# Ignore  the .env file that may contain sensitive information
.env

# Ignore generated RAG artifacts and local data
uploaded_pdfs/
vector_store/
chroma_db/
RAG/uploaded_pdfs/
RAG/vector_store/
RAG/chroma_db/
RAG/.env
SUMMARY.md